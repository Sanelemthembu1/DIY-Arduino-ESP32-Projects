void DrawBackground(){
  display.drawBitmap(2, 2, epd_bitmap_lablogo, 21, 17, SSD1306_WHITE);
  //epd_bitmap_clod1


  // Which world-tile is currently under the left edge of the camera?
  int screen = (int)(worldOffset / 128);


  // Draw that tile and the one after it, so there's always a tile
  // sliding in from the right before the current one fully exits.
  for (int s = screen; s <= screen + 1; s++) {
    int x = s * 128 - (int)worldOffset;
    
    display.drawBitmap(90+x, 0, epd_bitmap_clod1, 22, 12, SSD1306_WHITE);


    if (s < FINAL_SCREEN) {
      display.drawBitmap(x, 0, epd_bitmap_background2, 128, 64, SSD1306_WHITE);
    }
    else if (s == FINAL_SCREEN) {
      display.drawBitmap(x, 0, epd_bitmap_lastframe, 128, 64, SSD1306_WHITE);
    }
    // s > FINAL_SCREEN: nothing to draw, world ends there
  }
}


