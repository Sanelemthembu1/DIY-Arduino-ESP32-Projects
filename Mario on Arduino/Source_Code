// Returns the y of the stair tread under a given WORLD x, or -1 if none
int getStairTreadY(float worldX) {
  float localX = worldX - FINAL_SCREEN * 128; // convert to lastframe-local coords
  for (int s = 0; s < NUM_STAIRS; s++) {
    if (localX >= stairXStart[s] && localX < stairXEnd[s]) {
      return stairTreadY[s];
    }
  }
  return -1;
}


