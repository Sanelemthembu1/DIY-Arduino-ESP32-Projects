void createFlower() {


    display.drawBitmap(flowerX - worldOffset,
                       flowersY[(int)z],
                       epd_bitmap_flowers[(int)z],
                       15,
                       flowerpxy[(int)z],
                       SSD1306_WHITE);


    unsigned long now = millis();


    if (flowerWaiting) {
        // Wait 3 seconds before moving
        if (now - flowerTimer >= 3000) {
            flowerWaiting = false;
        }
    }
    else {
        // Animate
        z += flowerDirection;


        if (z >= 4) {
            z = 4;
            flowerDirection = -0.5;
            flowerWaiting = true;
            flowerTimer = now;   // Pause at the top
        }


        if (z <= 0) {
            z = 0;
            flowerDirection = 0.5;
            flowerWaiting = true;
            flowerTimer = now;   // Pause at the bottom
        }
    }
}


