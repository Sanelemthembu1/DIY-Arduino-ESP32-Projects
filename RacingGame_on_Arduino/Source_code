//dino_movement_and_physics
float vx = 0;
float vy = 0;


const float gravity = 0.4;
const float moveSpeed = 0.5;
const float jumpForce = -4.5;


bool onGround = true;
int cdino=0;


void moveDino(){


  int joyX = analogRead(A0);
  int joyY = analogRead(A1);


    if (gameEnded) {
        display.drawBitmap(Dino_x, Dino_y, epd_bitmap_dino[0], 20, 19, SSD1306_WHITE);
        display.drawBitmap(30, 26, epd_bitmap_Game_over, 63, 8, SSD1306_WHITE);
        return;
    }


  // Left/right movement
  if (joyX < 400)
    vx -= moveSpeed;


  else if (joyX > 600)
    vx += moveSpeed;
  else vx=0;
  // Friction
  vx *= 0.9;


  // Jump
  if (joyY > 600 && onGround) {
    vy = jumpForce;
    onGround =false;
  }


  // Gravity
  vy += gravity;


  // Update position
 Dino_x += vx;
  Dino_y += vy;


  // Ground collisions


if (Dino_y > 39) {
   Dino_y=39;
    vy = 0;
    onGround = true;
}


// Dino hitbox (slightly inset from the 20x19 bitmap)
float dx1 = Dino_x + 5;
float dx2 = Dino_x + 15;
float dy1 = Dino_y + 3;
float dy2 = Dino_y + 15;


// Obstacle 1 (10x21)
if (dx2 > obstacle1_x &&
    dx1 < obstacle1_x + 10 &&
    dy2 > obstacle1_y &&
    dy1 < obstacle1_y + 21)
{ gameEnded = true; }


// Obstacle 2 (6x11)
if (dx2 > obstacle2_x &&
    dx1 < obstacle2_x + 6 &&
    dy2 > obstacle2_y &&
    dy1 < obstacle2_y + 11)
{ gameEnded = true; }


// Obstacle 3 (6x11)
if (dx2 > obstacle3_x &&
    dx1 < obstacle3_x + 6 &&
    dy2 > obstacle3_y &&
    dy1 < obstacle3_y + 11)
{ gameEnded = true; }


// Car 1 (29x17)
if (dx2 > car1_x &&
    dx1 < car1_x + 29 &&
    dy2 > car1_y &&
    dy1 < car1_y + 17)
{ gameEnded = true; }




  if (Dino_x < 0) {
   Dino_x = 0;
    vx = 0;
  }


  if (Dino_x > 120) {
   Dino_x = 120;
    vx = 0;
  }
 
  if(cdino>2) cdino=0;
  display.drawBitmap(Dino_x, Dino_y, epd_bitmap_dino[cdino], 20, 19, SSD1306_WHITE);
  


  cdino++;
}


void updateScore(float &scoreTemp){
    display.setCursor(70, 3);
    display.setTextColor(SSD1306_WHITE);
    display.print("Score: ");
    display.print((int)scoreTemp);


}


void gameOver(){
   //display.clearDisplay();
   display.drawBitmap(30, 26, epd_bitmap_Game_over, 128, 64, SSD1306_WHITE);
   
}
void peep() {
  tone(BUZZER, 1200, 80); // frequency, duration
}
void gameOverBeep() {
  tone(BUZZER, 1000, 80);
  delay(90);
  tone(BUZZER, 800, 80);
  delay(90);
  tone(BUZZER, 600, 120);
  delay(130);
  tone(BUZZER, 300, 250);
}
void setup() {
pinMode(BUZZER, OUTPUT);
display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
display.clearDisplay();
startScreen();
display.display();
};


void loop()
{   
  int joyX = analogRead(A0);
  int joyY = analogRead(A1);
  if (joyX < 400) gameStarted = true;


  else if (joyX > 600) gameStarted = true;
if(gameStarted){
display.clearDisplay();
DrawBackground();
moveObstacles();
moveDino();
}
display.display();
};

