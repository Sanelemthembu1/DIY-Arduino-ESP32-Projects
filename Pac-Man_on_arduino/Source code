// --- non-blocking sound state ---
unsigned long soundStartTime = 0;
bool soundActive = false;
SoundType currentSound = SOUND_NONE;


void startSound(SoundType type) {
  currentSound = type;
  soundActive = true;
  soundStartTime = millis();
}


void updateSound() {
  if (!soundActive) return;
  unsigned long elapsed = millis() - soundStartTime;


  if (currentSound == SOUND_EAT) {
    // single short peep, ~40ms
    if (elapsed < 40) {
      digitalWrite(BUZZER_PIN, HIGH);
    } else {
      digitalWrite(BUZZER_PIN, LOW);
      soundActive = false;
    }
  }
  else if (currentSound == SOUND_DEATH) {
    // two beeps: on 0-80, off 80-140, on 140-220, then off
    if (elapsed < 80) {
      digitalWrite(BUZZER_PIN, HIGH);
    } else if (elapsed < 140) {
      digitalWrite(BUZZER_PIN, LOW);
    } else if (elapsed < 220) {
      digitalWrite(BUZZER_PIN, HIGH);
    } else {
      digitalWrite(BUZZER_PIN, LOW);
      soundActive = false;
    }
  }
}
