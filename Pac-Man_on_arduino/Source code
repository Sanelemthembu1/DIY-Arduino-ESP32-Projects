// Finds the *nearest* node sharing an axis with `from`, in direction `dir`.
bool findNeighbor(Point from, Direction dir, Point &result) {
  int bestDist = 32767;
  bool found = false;
  for (int i = 0; i < numPoints; i++) {
    Point p = validPaths[i];
    if (p.x == from.x && p.y == from.y) continue;
    if (dir == UP    && p.x == from.x && p.y < from.y) { int d = from.y - p.y; if (d < bestDist){bestDist=d; result=p; found=true;} }
    if (dir == DOWN  && p.x == from.x && p.y > from.y) { int d = p.y - from.y; if (d < bestDist){bestDist=d; result=p; found=true;} }
    if (dir == LEFT  && p.y == from.y && p.x < from.x) { int d = from.x - p.x; if (d < bestDist){bestDist=d; result=p; found=true;} }
    if (dir == RIGHT && p.y == from.y && p.x > from.x) { int d = p.x - from.x; if (d < bestDist){bestDist=d; result=p; found=true;} }
  }
  return found;
}


void generatePellets() {
  pelletCount = 0;
  for (int i = 0; i < numEatablePoints; i++) {
    pellets[pelletCount++] = { (uint8_t)eatablePoints[i].x, (uint8_t)eatablePoints[i].y, false };
  }
}


void drawPellets() {
  for (int i = 0; i < pelletCount; i++) {
    if (!pellets[i].eaten) {
      display.fillCircle(pellets[i].x, pellets[i].y, 1, SSD1306_WHITE);
    }
  }
}
