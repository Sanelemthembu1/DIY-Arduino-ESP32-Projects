    // Mid-edge: allow instant reversal (classic Pac-Man feel)
    Direction opp = (currentDir==RIGHT)?LEFT : (currentDir==LEFT)?RIGHT :
                    (currentDir==UP)?DOWN   : (currentDir==DOWN)?UP : NONE;
    if (desiredDir == opp) {
      Point tmp = fromNode;
      fromNode = toNode;
      toNode = tmp;
      currentDir = desiredDir;
    }
  }


  // Step one pixel per frame toward toNode, constrained to the graph edge
  if (currentDir == RIGHT && pacX < toNode.x) pacX++;
  if (currentDir == LEFT  && pacX > toNode.x) pacX--;
  if (currentDir == DOWN  && pacY < toNode.y) pacY++;
  if (currentDir == UP    && pacY > toNode.y) pacY--;


  for (int i = 0; i < pelletCount; i++) {
    if (!pellets[i].eaten &&
        abs((int)pacX - pellets[i].x) <= 2 &&
        abs((int)pacY - pellets[i].y) <= 2) {
      pellets[i].eaten = true;
      score++;
      //startSound(SOUND_EAT);
    }
  }
 D+=pacD;
 U+=pacU;
 L+=pacL;
 R+=pacR;
  if(U>2)pacU=-0.5;
  if(L>2)pacL=-0.5;
  if(R>2)pacR=-0.5;
  if(D>2)pacD=-0.5;
    if(U<0)pacU=0.5;
  if(L<0)pacL=0.5;
  if(R<0)pacR=0.5;
  if(D<0)pacD=0.5;


const uint8_t* sprite = epd_bitmap_Pac[2];
if (currentDir == LEFT)  {
  sprite = epd_bitmap_allArray_L[(int)L];
}
if (currentDir == DOWN)  {
  sprite = epd_bitmap_allArray_D[(int)D];
}
if (currentDir == UP)    {
  sprite = epd_bitmap_allArray_U[(int)U];
}
if (currentDir == RIGHT) {
  sprite = epd_bitmap_allArray_R[(int)R];
}


  display.drawBitmap(pacX, pacY, sprite, 5, 5, SSD1306_WHITE);
}


void moveGhostRandom(Ghost &g) {
  bool atNode = (g.x == g.toNode.x && g.y == g.toNode.y);


  if (atNode) {
    Direction all[4] = {UP, DOWN, LEFT, RIGHT};
    Direction opp = oppositeDir(g.currentDir);


    Direction options[4];
    int count = 0;
    Point next;


    for (int i = 0; i < 4; i++) {
      if (all[i] == opp) continue;
      if (findNeighbor(g.toNode, all[i], next)) {
        options[count++] = all[i];
      }
    }


    if (count == 0 && opp != NONE && findNeighbor(g.toNode, opp, next)) {
      options[count++] = opp;
    }


    if (count > 0) {
      Direction chosen = options[random(count)];
      findNeighbor(g.toNode, chosen, next);
      g.fromNode = g.toNode;
      g.toNode   = next;
      g.currentDir = chosen;
    }
  }


  if (g.currentDir == RIGHT && g.x < g.toNode.x) g.x++;
  if (g.currentDir == LEFT  && g.x > g.toNode.x) g.x--;
  if (g.currentDir == DOWN  && g.y < g.toNode.y) g.y++;
  if (g.currentDir == UP    && g.y > g.toNode.y) g.y--;
}


void drawScore() {
  display.setTextSize(1);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(0, 56);
  display.print("S:");
  display.print(score);
}


bool checkGhostCollision() {
  for (int i = 0; i < 4; i++) {
    if (abs(pacX - ghosts[i].x) <= COLLISION_RADIUS &&
        abs(pacY - ghosts[i].y) <= COLLISION_RADIUS) {
      return true;
    }
  }
  return false;
}


void respawnPac() {
  pacX = PAC_START_X;
  pacY = PAC_START_Y;
  fromNode = {(int)PAC_START_X, (int)PAC_START_Y};
  toNode   = {(int)PAC_START_X, (int)PAC_START_Y};
  currentDir = NONE;
  desiredDir = NONE;
}


void moveGhost(){
  for (int i = 0; i < 4; i++) {
    moveGhostRandom(ghosts[i]);
    display.drawBitmap(ghosts[i].x, ghosts[i].y, epd_bitmap_pacaOppR, 6, 5, SSD1306_WHITE);
  }


  if (checkGhostCollision()) {
    respawnPac();
    //startSound(SOUND_DEATH);
  }
}


void setup(){
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  randomSeed(analogRead(A2));
  generatePellets();
  pinMode(2, OUTPUT);
digitalWrite(BUZZER_PIN, LOW);
  display.display();
}


void loop(){
  display.clearDisplay();
  drawPacBackground();
  drawPellets();
  movePac();
  updateSound();
  moveGhost();
  drawScore();
  display.display();
}



