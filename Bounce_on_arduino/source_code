};


void loop()
{   display.clearDisplay();
    int joyX = analogRead(A0);
    int joyY = analogRead(A1);
//press key to start game
    if (joyX < 400)
    gameStarted = true;


    else if (joyX > 600)
    gameStarted=true;


    if(gameWon){
    display.clearDisplay();
    display.drawBitmap(0, 0, epd_bitmap_win_screen,
                       128, 64, SSD1306_WHITE);


    // wait for joystick movement to restart
    int joyX = analogRead(A0);


    if(joyX < 400 || joyX > 600){
        gameWon = false;
        lives = 3;
        ball_x = 6;
        ball_y = 32;
        vx = 0;
        vy = 0;
    }
}
else if(gameStarted){
    DrawBackground();
    moveBall();
    moveObstacles();
    drawLives(lives);
}
//else if(gameEnded==true){gameOver();gameEnded=false;}
    
    


else if(gameEnded){
    display.clearDisplay();
    display.drawBitmap(0, 0, epd_bitmap_lose_screen,
                       128, 64, SSD1306_WHITE);


    int joyX = analogRead(A0);


    if(joyX < 400 || joyX > 600){
        gameEnded = false;
        lives = 3;
        ball_x = 6;
        ball_y = 32;
        vx = 0;
        vy = 0;
    }
}
else{
    startScreen();
}


display.display();
};

