//ball_movement_and_physics
float vx = 0;
float vy = 0;


const float gravity = 0.3;
const float moveSpeed = 0.3;
const float jumpForce = -3.0;


bool onGround = true;


void moveBall(){


  int joyX = analogRead(A0);
  int joyY = analogRead(A1);


  // Left/right movement
  if (joyX < 400)
    vx -= moveSpeed;


  else if (joyX > 600)
    vx += moveSpeed;
  else vx=0;
  // Friction
  vx *= 0.9;


  // Jump
  if (joyY > 600 && onGround) {
    vy = jumpForce;
    onGround =false;
  }


  // Gravity
  vy += gravity;


  // Update position
  ball_x += vx;
  ball_y += vy;


  // Ground collisions


if (ball_y > 55) {
   delay(500);
   ball_x=6;
   ball_y=32;
    vy = 0;
    onGround = true;
    lives--;
}
if (ball_x >= -1 && ball_x < 17 && vy >= 0) {
    if (ball_y >= 33) {
        ball_y = 33;
        vy = 0;
        onGround = true;
    }
}
if (ball_x >= 12 && ball_x <= 21 && vy >= 0) {
    if (ball_y >= 27) {
        ball_y = 27;
        vy = 0;
        onGround = true;
    }
}
if (ball_x >= obstacle1_x && ball_x <= obstacle1_x + 16 && vy >= 0) {
    if (ball_y >= 38) {
        ball_y = 38;
        vy = 0;
        ball_x +=obstacle1_direction;
        if(ball_x >= obstacle1_x+6 && ball_x <= obstacle1_x + 10 && vy >= 0){
            lives--;
            delay(500);
            ball_x=6;
            ball_y=32;
        }


        onGround = true;
    }
}
if (ball_x >= obstacle2_x && ball_x <= obstacle2_x + 16 && vy >= 0) {
    if (ball_y >= 38) {
        ball_y = 38;
        vy = 0;
        ball_x +=obstacle2_direction;
        if(ball_x >= obstacle1_x+4 && ball_x <= obstacle1_x + 4 && vy >= 0){
            lives--;
            delay(500);
            ball_x=6;
            ball_y=32;
        }
        onGround = true;
    }
}
if (ball_x >= 74 && ball_x <= 86 && vy >= 0) {
    if (ball_y >= 33) {
        ball_y = 33;
        vy = 0;
        onGround = true;
    }
}
if (ball_x > 86 && ball_x <= 99 && vy >= 0) {
    if (ball_y >= 37) {
        ball_y = 37;
        vy = 0;
        onGround = true;
    }
}


if (ball_x >= obstacle3_x-5 && ball_x <= obstacle3_x + 5 && vy >= 0) {
    if (ball_y >= obstacle3_y-7) {
        ball_y = obstacle3_y-7;
        vy = 0;
        ball_y +=obstacle3_direction;
        onGround = true;
    }
}
if (ball_x > 108 && ball_x <= 129 && vy >= 0) {
    if (ball_y >= 37) {
        ball_y = 37;
        vy = 0;
    if(ball_x > 120 && ball_x <= 129 && vy >= 0){
        youWin();
        
    }


        onGround = true;
    }
}


  if (ball_x < 0) {
    ball_x = 0;
    vx = 0;
  }


  if (ball_x > 120) {
    ball_x = 120;
    vx = 0;
  }
  
  display.drawBitmap(ball_x, ball_y, epd_bitmap_ball, 7, 7, SSD1306_WHITE);
}


