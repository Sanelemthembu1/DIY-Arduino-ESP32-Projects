#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define NUM_PIPES 4


#define PIPE_SPACING_MIN 34
#define PIPE_SPACING_MAX 55


#define GAP_HEIGHT_MIN 22   // smaller = harder
#define GAP_HEIGHT_MAX 34   // bigger  = easier


bool pipeScored[NUM_PIPES] = { false }; // tracks which pipes have already triggered a beep


int pipeX[NUM_PIPES]        = {128, 168, 208, 248}; // seed values, fine as-is
int pipeGapY[NUM_PIPES]     = {25, 39, 10, 40};      // gap top position
int pipeGapH[NUM_PIPES]     = {28, 28, 28, 28};      // gap height (NEW)


bool  pipeOscillate[NUM_PIPES] = { false };
float pipeGapYf[NUM_PIPES];      // float version of pipeGapY, for smooth motion
int   pipeOscDir[NUM_PIPES];     // +1 or -1
int   pipeOscMin[NUM_PIPES];
int   pipeOscMax[NUM_PIPES];
const float pipeOscSpeed = 0.5;  // vertical speed of oscillation, tune to taste


void drawPipes()
{
    for (int i = 0; i < NUM_PIPES; i++)
    {
        pipeX[i] -= 2;
        if (pipeX[i] < -20)
        {
            int furthest = pipeX[0];
            for (int j = 1; j < NUM_PIPES; j++)
                if (pipeX[j] > furthest)
                    furthest = pipeX[j];
            int spacing = random(PIPE_SPACING_MIN, PIPE_SPACING_MAX + 1);
            pipeX[i] = furthest + spacing;


            pipeGapH[i] = random(GAP_HEIGHT_MIN, GAP_HEIGHT_MAX + 1);


            // Keep the gap fully on-screen given the new random height
            int minGapY = 5;
            int maxGapY = SCREEN_HEIGHT - pipeGapH[i] - 5;
            pipeGapY[i] = random(minGapY, maxGapY + 1);
            pipeGapYf[i] = pipeGapY[i]; // sync float tracker


            pipeScored[i] = false;


            // 60% chance this pipe pair oscillates up/down
            pipeOscillate[i] = (random(0, 10) < 6);            
        if (pipeOscillate[i]) {
                pipeOscMin[i] = minGapY;
                pipeOscMax[i] = maxGapY;
                pipeOscDir[i] = (random(0, 2) == 0) ? 1 : -1; // random starting direction
            }
        }


        // Update oscillation before drawing/collision
        if (pipeOscillate[i]) {
            pipeGapYf[i] += pipeOscDir[i] * pipeOscSpeed;
            if (pipeGapYf[i] >= pipeOscMax[i]) { pipeGapYf[i] = pipeOscMax[i]; pipeOscDir[i] = -1; }
            if (pipeGapYf[i] <= pipeOscMin[i]) { pipeGapYf[i] = pipeOscMin[i]; pipeOscDir[i] = 1; }
            pipeGapY[i] = (int)pipeGapYf[i]; // keep int version in sync for collision/scoring
        }


        int topY    = pipeGapY[i] - 42;
        int bottomY = pipeGapY[i] + pipeGapH[i];
        display.drawBitmap(pipeX[i], topY,
                            epd_bitmap_pipet,
                            13, 42, SSD1306_WHITE);
        display.drawBitmap(pipeX[i], bottomY,
                            epd_bitmap_pipeD,
                            13, 42, SSD1306_WHITE);
    }
}
int birdTPX[3] = {14,14,14};
int birdTPY[3] = {11,11,11};
int birdBPX[3] = {14,17,15};
int birdBPY[3] = {12,12,12};
int birdDPX[3] = {11,11,11};
int birdDPY[3] = {14,14,14};


float frameT = 0;      // frame index while button held (flappt)
float frameD = 0;      // frame index while falling (flappd)
int dirT = 1;           // +1 or -1, ping-pong direction for flappt
int dirD = 1;           // +1 or -1, ping-pong direction for flappd
const float frameSpeed = 1.5;


bool wasPressed = false;
unsigned long releaseTime = 0;
const unsigned long fallDelay = 300; // ms grace period before sprite switches to falling


void moveBird()
{
    bool isPressed = (digitalRead(BUTTON) == LOW);


    // Detect the moment button is released — start the grace timer
    if (wasPressed && !isPressed) {
        releaseTime = millis();
    }


    // Reset falling animation next time we actually enter fall-sprite state
    if (!wasPressed && isPressed) {
        frameD = 0;
        dirD = 1;
    }


    bool inGracePeriod = (!isPressed) && (millis() - releaseTime < fallDelay);
    bool showUpSprite = isPressed || inGracePeriod;


    if (isPressed) {
        birdY -= 4; // only real button press applies upward force
    } else {
        birdY += 2; // released: always physically falling, no extra lift
    }


    if (showUpSprite) {
        // Still show the "flapping up" sprite (even if already falling physically)
        frameT += dirT * frameSpeed;
        if (frameT >= 2) { frameT = 2; dirT = -1; }
        if (frameT <= 0) { frameT = 0; dirT = 1; }


        int idx = (int)frameT;
        display.drawBitmap(birdX, birdY, epd_bitmap_flappbw[idx],
                            birdBPX[idx], birdBPY[idx], SSD1306_WHITE);
    } else {
        // Grace period expired — now show the falling sprite
        frameD += dirD * frameSpeed;
        if (frameD >= 2) { frameD = 2; dirD = -1; }
        if (frameD <= 0) { frameD = 0; dirD = 1; }


        int idx = (int)frameD;
        display.drawBitmap(birdX, birdY, epd_bitmap_flappd[idx],
                            birdDPX[idx], birdDPY[idx], SSD1306_WHITE);
    }


    wasPressed = isPressed;


    // Clamp so bird can't go above screen top
    if (birdY < 0) birdY = 0;


    if (checkCollision()) {
        isgameOver = true;
    }
}
#define BIRD_W 15
#define BIRD_H 10
#define PIPE_W 11
#define PIPE_H 40


bool checkCollision()
{
    // Ceiling / ground collision
    if (birdY <= 0 || birdY + BIRD_H >= SCREEN_HEIGHT)
        return true;


    // Pipe collision (AABB overlap test)
    for (int i = 0; i < NUM_PIPES; i++)
    {
        int topY    = pipeGapY[i] - 42;
        int bottomY = pipeGapY[i] + pipeGapH[i];


        bool overlapX = (birdX < pipeX[i] + PIPE_W) && (birdX + BIRD_W > pipeX[i]);
        bool overlapTop    = (birdY < topY + PIPE_H) && (birdY + BIRD_H > topY);
        bool overlapBottom = (birdY < bottomY + PIPE_H) && (birdY + BIRD_H > bottomY);


        if (overlapX && (overlapTop || overlapBottom))
            return true;


        // Scoring: bird's leading edge has passed the pipe's trailing edge
        if (!pipeScored[i] && (birdX > pipeX[i] + PIPE_W)) {
            pipeScored[i] = true;
            score++; 
            tone(BUZZER_PIN, 1000, 100); // 1000Hz for 100ms — a short "ding"
        }
    }
    return false;
}


void drawScore() {
  display.setTextSize(2);
  display.setTextColor(SSD1306_WHITE);
  display.setCursor(60, 5);
  display.print(score);
}


void gameOver(){
  if(isgameOver){
    display.setCursor(10,20);
    display.setTextSize(2);
    display.setTextColor(SSD1306_WHITE);
    display.print("Game Over");
  }


}
void resetGame()
{
    birdY = SCREEN_HEIGHT / 2;
    score = 0;
    isgameOver = false;
    for (int i = 0; i < NUM_PIPES; i++) {
        pipeX[i] = 128 + i * 40; 
        pipeScored[i] = false;
        pipeOscillate[i] = false;
    }
}
void setup(){
  display.begin(SSD1306_SWITCHCAPVCC, 0x3C);
  pinMode(BUTTON,INPUT_PULLUP);
  //randomSeed(analogRead(A2));
  display.display();
}


void loop()
{
    display.clearDisplay();


    if (!isgameOver) {
        drawFlappBackground();
        drawPipes();
        moveBird();
        drawScore();
    } else {
        // Redraw last-known static scene without updating anything
        display.drawBitmap(back1_x, 57, epd_bitmap_floor1, 128, 7, SSD1306_WHITE);
        display.drawBitmap(back2_x, 57, epd_bitmap_floor1, 128, 7, SSD1306_WHITE);
        display.drawBitmap(0, 0, epd_bitmap_backB1, 128, 58, SSD1306_WHITE);


        for (int i = 0; i < NUM_PIPES; i++) {
            int topY    = pipeGapY[i] - 42;
            int bottomY = pipeGapY[i] + pipeGapH[i];
            display.drawBitmap(pipeX[i], topY, epd_bitmap_pipet, 13, 42, SSD1306_WHITE);
            display.drawBitmap(pipeX[i], bottomY, epd_bitmap_pipeD, 13, 42, SSD1306_WHITE);
        }


        display.drawBitmap(birdX, birdY, epd_bitmap_flappbw[(int)frameT],
                            birdBPX[(int)frameT], birdBPY[(int)frameT], SSD1306_WHITE);


        // Draw your "Game Over" text/graphic here
        display.drawBitmap(1, 1, epd_bitmap_logo, 21, 17, SSD1306_WHITE);
        gameOver();
        drawScore();
        if(digitalRead(BUTTON)==LOW) resetGame();
    }


    display.display();
}



